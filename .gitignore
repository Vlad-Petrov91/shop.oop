# Ignore Composer dependencies
/vendor/
# optional, usually you want to commit this to lock dependency versions
/composer.lock 


# Ignore sensitive configuration files
# config.php
.env
# or a directory for configs
/config/*.local.php

# Ignore temporary files and logs
*.log
*.sql
*.sqlite
/tmp/
/cache/

# Ignore session files
/sessions/

# Ignore IDE and OS generated files
.DS_Store
ehthumbs.db
Thumbs.db
.idea/
.vscode/

# If you use Node.js for front-end assets
/node_modules/

# If you use a specific framework (e.g., Laravel, Symfony),
# you'll need additional rules specific to that framework.
